version: "1"

# --- Branch isolation for writing agents ---
# isolation: branch           # branch (default) | worktree | none

# --- Force HOTL execution (auto-detected when omitted) ---
# pipeline: hotl

# --- Final verification (runs after all stages) ---
# Auto-detected from repo signals when omitted (pytest, npm test, etc.)
final_verify:
  - "python3 -m pytest -v"
# final_verify_policy: block   # block (default) | warn
# final_verify_max_retries: 1

# --- Role overrides (deep-merged with built-in defaults) ---
# Model routing: analysis roles benefit from strong reasoning models,
# execution roles benefit from fast coding models. Model selection is
# a personal override (share-config strips it from team config).
#
# Analysis roles (uncomment in personal config):
#   researcher:
#     model: o3-pro            # strong reasoning for research
#   pm:
#     model: o3-pro            # strong reasoning for strategy
#   architect:
#     model: o3-pro            # strong reasoning for design
#   reviewer:
#     model: o3-pro            # strong reasoning for review
#
# Cross-model review: use different models for dev and reviewer
# to avoid sycophantic reviews. See docs/configuration.md.

roles:
  dev:
    model: gpt-5.3-codex
    can_write: true
    write_scope:
      - "src/**"
      - "lib/**"
      - "docs/plans/**"

  qa:
    model: gpt-5.3-codex
    can_write: true
    write_scope:
      - "tests/**"
      - "**/*.test.*"

  # Custom role example — uncomment and modify
  # security_auditor:
  #   description: "Reviews code for security vulnerabilities"
  #   participates_in: [review]
  #   can_write: false
  #   system_instructions: |
  #     Focus on OWASP top 10, auth/authz logic, and hardcoded secrets.

# --- Pipeline stages ---
# verify: shell command that must exit 0 (auto-detected when omitted)
# max_retries: re-dispatch on verify failure (default: 0)
pipeline:
  stages:
    - name: research
      roles: [researcher]
      gate: auto

    - name: strategy
      roles: [pm]
      gate: human

    - name: design
      roles: [architect, pm, researcher]
      gate: human
      verify: "test -f docs/designs/*.md"

    - name: plan
      roles: [dev]
      gate: human

    - name: implement
      roles: [dev]
      gate: auto
      max_retries: 2
      # criteria:                   # lightweight gate checks (optional)
      #   max_files_changed: 15     # block if too many files changed
      #   scope_paths: ["src/**"]   # block if files outside these patterns
      #   requires_tests: true      # block if no test files modified

    - name: test
      roles: [qa]
      gate: auto
      max_retries: 1
      rework_to: implement          # on test failure, dispatch dev to fix code first

    - name: review
      roles: [reviewer]
      gate: human

  # --- Pipeline profiles (optional) ---
  # Named subsets of stages for different task sizes.
  # Omit for full pipeline on every run.
  # profiles:
  #   quick:
  #     stages: [implement, test]
  #     hints:
  #       - typo
  #       - one-line fix
  #       - config change
  #       - version bump
  #   standard:
  #     stages: [design, plan, implement, test, review]
  #     hints:
  #       - new endpoint
  #       - refactor
  #       - add feature
  #       - fix bug
  #   collaborative:
  #     stages: [research, strategy, design, implement, test, review]
  #     hints:
  #       - new feature
  #       - build something
  #       - design and implement
